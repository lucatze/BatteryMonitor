<UserControl x:Class="BatteryMonitor.Controls.GaugeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="150" Height="155">
    <Grid>
        <!-- Arc gauge drawn in code-behind -->
        <Canvas x:Name="ArcCanvas" Width="120" Height="120"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>

        <!-- Center value -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,32,0,0">
            <TextBlock x:Name="ValueText"
                       FontSize="30" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="#F0F2F8"/>
            <TextBlock x:Name="UnitText"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Foreground="#6B7A99"/>
        </StackPanel>

        <!-- Label directly below arc -->
        <TextBlock x:Name="LabelText"
                   FontSize="10" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Foreground="#4A9EFF" Margin="0,0,0,2"/>
    </Grid>
</UserControl>
